{
  "name": "termpaperr-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Express API (TypeScript)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migration:generate": "tsx ./node_modules/typeorm/cli.js migration:generate -d ./src/config/data-source.ts",
    "migration:run": "tsx ./node_modules/typeorm/cli.js migration:run -d ./src/config/data-source.ts",
    "migration:revert": "tsx ./node_modules/typeorm/cli.js migration:revert -d ./src/config/data-source.ts",
    "migration:show": "tsx ./node_modules/typeorm/cli.js migration:show -d ./src/config/data-source.ts",
    "migration:baseline": "tsx scripts/baseline-migrations.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.29",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.2",
    "@types/nodemailer": "^8.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
