NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://termpaperr:termpaperr@127.0.0.1:5432/termpaperr

# TypeORM
# For development you can keep true to auto-sync schema.
# For production use false and run migrations.
TYPEORM_SYNC=true
# Copy to .env and adjust. Used by docker compose variable substitution and the app.

POSTGRES_USER=termpaperr
POSTGRES_PASSWORD=termpaperr
POSTGRES_DB=termpaperr
POSTGRES_PORT=5432

REDIS_PORT=6379

# From host / Node app (containers use service names on the Docker network)
DATABASE_URL=postgresql://termpaperr:termpaperr@localhost:5432/termpaperr
REDIS_URL=redis://localhost:6379

# TypeORM: schema sync (dev only; use migrations in prod)
TYPEORM_SYNC=false

# JWT (access sign / TTL); refresh TTL also used for Redis key EX
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Public URL of this API (used in registration / email verification links)
APP_PUBLIC_URL=http://localhost:3000

# Email verification token lifetime (ms-style string, see "ms" package)
EMAIL_VERIFICATION_EXPIRES_IN=24h

# Outgoing email (nodemailer). Optional in dev: links are logged to console if unset.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
